<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:swipeCardView="clr-namespace:Plugin.Maui.SwipeCardView;assembly=Plugin.Maui.SwipeCardView"
             x:Class="SwipeCardView.Sample.Views.TinderPage"
             BackgroundColor="White"
             Shell.BackgroundColor="White"
             Shell.TitleColor="#333333"
             Shell.ForegroundColor="#333333"
             Title ="Tinder">

    <Grid RowDefinitions="*,Auto" Padding="0">
        <swipeCardView:SwipeCardView
            x:Name="SwipeCardView"
            ItemsSource="{Binding Profiles}"
            HorizontalOptions="FillAndExpand"
            VerticalOptions="FillAndExpand"
            Padding="8,4,8,24"
            SwipedCommand="{Binding SwipedCommand}"
            DraggingCommand="{Binding DraggingCommand}"
            Threshold="{Binding Threshold}"
            SupportedSwipeDirections="Left, Right, Up"
            SupportedDraggingDirections="Left, Right, Up, Down"
            LoopCards="True"
            StackDepth="2"
            StackOffset="15"
            BackCardScale="0.95">
            <swipeCardView:SwipeCardView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 12"
                            Stroke="#E8E8E8"
                            StrokeThickness="1"
                            Padding="0"
                            InputTransparent="True"
                            BackgroundColor="White"
                            HorizontalOptions="FillAndExpand"
                            VerticalOptions="FillAndExpand">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,4" Radius="16" Opacity="0.12" />
                        </Border.Shadow>
                        <Grid>
                            <!-- Photo fills entire card -->
                            <Image Source="{Binding Photo}" Aspect="AspectFill" />

                            <!-- Bottom gradient overlay for text readability -->
                            <BoxView VerticalOptions="End" HeightRequest="180"
                                     InputTransparent="True">
                                <BoxView.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="Transparent" Offset="0.0" />
                                        <GradientStop Color="#AA000000" Offset="0.6" />
                                        <GradientStop Color="#DD000000" Offset="1.0" />
                                    </LinearGradientBrush>
                                </BoxView.Background>
                            </BoxView>

                            <!-- Profile info over gradient -->
                            <VerticalStackLayout VerticalOptions="End"
                                                 Padding="20,0,20,20" Spacing="2"
                                                 InputTransparent="True">
                                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                    <Label Text="{Binding Name}" FontSize="26"
                                           FontAttributes="Bold" TextColor="White" />
                                    <Label Text="{Binding Age}" FontSize="26"
                                           TextColor="#DDDDDD" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="6" Margin="0,4,0,0">
                                    <Label Text="🎓" FontSize="14" VerticalOptions="Center" />
                                    <Label Text="{Binding School}" FontSize="14"
                                           TextColor="#CCCCCC" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="6">
                                    <Label Text="📍" FontSize="14" VerticalOptions="Center" />
                                    <Label Text="{Binding Distance}" FontSize="14"
                                           TextColor="#CCCCCC" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <!-- LIKE overlay -->
                            <Border x:Name="LikeFrame"
                                    StrokeShape="RoundRectangle 8"
                                    Stroke="#63DD99" StrokeThickness="4"
                                    BackgroundColor="Transparent"
                                    Padding="16,8" Opacity="0"
                                    HorizontalOptions="Start" VerticalOptions="Start"
                                    Margin="24,32" Rotation="-20"
                                    InputTransparent="True">
                                <Label x:Name="LikeText" Text="LIKE" TextColor="#63DD99"
                                       FontSize="36" FontAttributes="Bold"
                                       HorizontalTextAlignment="Center" />
                            </Border>

                            <!-- NOPE overlay -->
                            <Border x:Name="NopeFrame"
                                    StrokeShape="RoundRectangle 8"
                                    Stroke="#FF4458" StrokeThickness="4"
                                    BackgroundColor="Transparent"
                                    Padding="16,8" Opacity="0"
                                    HorizontalOptions="End" VerticalOptions="Start"
                                    Margin="24,32" Rotation="20"
                                    InputTransparent="True">
                                <Label Text="NOPE" TextColor="#FF4458"
                                       FontSize="36" FontAttributes="Bold"
                                       HorizontalTextAlignment="Center" />
                            </Border>

                            <!-- SUPER LIKE overlay -->
                            <Border x:Name="SuperLikeFrame"
                                    StrokeShape="RoundRectangle 8"
                                    Stroke="#00D0FF" StrokeThickness="4"
                                    BackgroundColor="Transparent"
                                    Padding="16,8" Opacity="0"
                                    HorizontalOptions="Center" VerticalOptions="End"
                                    Margin="0,0,0,80" Rotation="-20"
                                    InputTransparent="True">
                                <Label Text="SUPER LIKE" TextColor="#00D0FF"
                                       FontSize="28" FontAttributes="Bold"
                                       HorizontalTextAlignment="Center" />
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </swipeCardView:SwipeCardView.ItemTemplate>
        </swipeCardView:SwipeCardView>

        <!-- Action buttons: rewind, nope, super like, like, boost -->
        <HorizontalStackLayout Grid.Row="1" HorizontalOptions="Center"
                               Padding="0,8,0,20" Spacing="16">
            <!-- Rewind (small) -->
            <Border x:Name="rewindButton" StrokeShape="RoundRectangle 22"
                    Stroke="Transparent" StrokeThickness="0"
                    BackgroundColor="White" WidthRequest="44" HeightRequest="44"
                    HorizontalOptions="Center" VerticalOptions="Center">
                <Border.Shadow>
                    <Shadow Brush="#888" Offset="0,2" Radius="8" Opacity="0.15" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnRewindClicked" />
                </Border.GestureRecognizers>
                <Image Source="ic_tinder_rewind.svg" WidthRequest="22" HeightRequest="22"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>

            <!-- Nope (large) -->
            <Border x:Name="nopeButton" StrokeShape="RoundRectangle 30"
                    Stroke="Transparent" StrokeThickness="0"
                    BackgroundColor="White" WidthRequest="60" HeightRequest="60"
                    HorizontalOptions="Center" VerticalOptions="Center">
                <Border.Shadow>
                    <Shadow Brush="#888" Offset="0,2" Radius="8" Opacity="0.15" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnDislikeClicked" />
                </Border.GestureRecognizers>
                <Image Source="ic_tinder_nope.png" WidthRequest="28" HeightRequest="28"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>

            <!-- Super Like (small) -->
            <Border x:Name="superLikeButton" StrokeShape="RoundRectangle 22"
                    Stroke="Transparent" StrokeThickness="0"
                    BackgroundColor="White" WidthRequest="44" HeightRequest="44"
                    HorizontalOptions="Center" VerticalOptions="Center">
                <Border.Shadow>
                    <Shadow Brush="#888" Offset="0,2" Radius="8" Opacity="0.15" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSuperLikeClicked" />
                </Border.GestureRecognizers>
                <Image Source="ic_tinder_superlike.png" WidthRequest="22" HeightRequest="22"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>

            <!-- Like (large) -->
            <Border x:Name="likeButton" StrokeShape="RoundRectangle 30"
                    Stroke="Transparent" StrokeThickness="0"
                    BackgroundColor="White" WidthRequest="60" HeightRequest="60"
                    HorizontalOptions="Center" VerticalOptions="Center">
                <Border.Shadow>
                    <Shadow Brush="#888" Offset="0,2" Radius="8" Opacity="0.15" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLikeClicked" />
                </Border.GestureRecognizers>
                <Image Source="ic_tinder_like.png" WidthRequest="28" HeightRequest="28"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>

            <!-- Boost (small) -->
            <Border x:Name="boostButton" StrokeShape="RoundRectangle 22"
                    Stroke="Transparent" StrokeThickness="0"
                    BackgroundColor="White" WidthRequest="44" HeightRequest="44"
                    HorizontalOptions="Center" VerticalOptions="Center">
                <Border.Shadow>
                    <Shadow Brush="#888" Offset="0,2" Radius="8" Opacity="0.15" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBoostClicked" />
                </Border.GestureRecognizers>
                <Image Source="ic_tinder_boost.svg" WidthRequest="22" HeightRequest="22"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
        </HorizontalStackLayout>
    </Grid>

</ContentPage>