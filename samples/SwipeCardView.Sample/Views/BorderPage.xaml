<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:swipeCardView="clr-namespace:Plugin.Maui.SwipeCardView;assembly=Plugin.Maui.SwipeCardView"
             x:Class="SwipeCardView.Sample.Views.BorderPage"
             Shell.BackgroundColor="{x:StaticResource Primary}"
             Shell.TitleColor="{x:StaticResource White}"
             Title="Border">

    <Grid RowDefinitions="*,Auto" Padding="16">
        <swipeCardView:SwipeCardView
            ItemsSource="{Binding CardItems}"
            SwipedCommand="{Binding SwipedCommand}"
            VerticalOptions="FillAndExpand"
            HorizontalOptions="FillAndExpand"
            Threshold="100">
            <swipeCardView:SwipeCardView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 20"
                            Stroke="{StaticResource Gray200}"
                            StrokeThickness="1"
                            BackgroundColor="White"
                            Padding="24"
                            InputTransparent="True">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,6" Radius="20" Opacity="0.15" />
                        </Border.Shadow>
                        <VerticalStackLayout HorizontalOptions="Center"
                                             VerticalOptions="Center"
                                             Spacing="12">
                            <Border StrokeShape="RoundRectangle 28"
                                    Stroke="Transparent"
                                    BackgroundColor="#F0EBFF"
                                    WidthRequest="56" HeightRequest="56"
                                    HorizontalOptions="Center">
                                <Label Text="📌"
                                       FontSize="28"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <Label Text="{Binding .}"
                                   FontSize="28"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{StaticResource Primary}" />
                            <Label Text="Border as DataTemplate root"
                                   FontSize="13"
                                   TextColor="{StaticResource Gray400}"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </swipeCardView:SwipeCardView.ItemTemplate>
        </swipeCardView:SwipeCardView>

        <VerticalStackLayout Grid.Row="1" Spacing="8" Padding="0,12,0,0">
            <Label Text="{Binding Message}" HorizontalOptions="Center" FontSize="14"
                   FontAttributes="Bold" TextColor="{StaticResource Primary}" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <Button Text="Clear" Command="{Binding ClearItemsCommand}"
                        BackgroundColor="#FFE8E5" TextColor="#E53935" FontSize="13" />
                <Button Grid.Column="1" Text="Add 5" Command="{Binding AddItemsCommand}" FontSize="13" />
            </Grid>
        </VerticalStackLayout>
    </Grid>

</ContentPage>
