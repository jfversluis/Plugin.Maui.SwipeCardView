<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:swipeCardView="clr-namespace:Plugin.Maui.SwipeCardView;assembly=Plugin.Maui.SwipeCardView"
             xmlns:local="clr-namespace:SwipeCardView.Sample"
             x:Class="SwipeCardView.Sample.Views.CustomizablePage"
             Shell.BackgroundColor="{x:StaticResource Primary}"
             Shell.TitleColor="{x:StaticResource White}"
             Title="Customizable">

    <Grid RowDefinitions="3*,Auto,2*" Padding="16" RowSpacing="8">
        <!-- Card area -->
        <swipeCardView:SwipeCardView
            x:Name="SwipeCardView"
            HorizontalOptions="FillAndExpand"
            VerticalOptions="FillAndExpand"
            ItemsSource="{Binding CardItems}"
            TopItem="{Binding TopItem}"
            SwipedCommand="{Binding SwipedCommand}"
            DraggingCommand="{Binding DraggingCommand}"
            SupportedDraggingDirections="{Binding SupportedDraggingDirections}"
            SupportedSwipeDirections="{Binding SupportedSwipeDirections}"
            Threshold="{Binding Threshold}"
            AnimationLength="{Binding AnimationLength}"
            BackCardScale="{Binding BackCardScale}"
            CardRotation="{Binding CardRotation}"
            LoopCards="{Binding IsLoopCards}"
            StackDepth="{Binding StackDepth}"
            StackOffset="{Binding StackOffset}"
            StackScaleStep="{Binding StackScaleStep}"
            StackDirection="{Binding StackDirection}"
            StackCardColor="{Binding StackCardColor}">
            <swipeCardView:SwipeCardView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 16"
                            Stroke="#E0D5F5"
                            StrokeThickness="2"
                            BackgroundColor="#FDFBFF"
                            Padding="0"
                            InputTransparent="True"
                            HorizontalOptions="FillAndExpand"
                            VerticalOptions="FillAndExpand">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,4" Radius="16" Opacity="0.1" />
                        </Border.Shadow>
                        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="4">
                            <Label Text="{Binding .}" FontSize="28" FontAttributes="Bold"
                                   HorizontalTextAlignment="Center" TextColor="{StaticResource Primary}" />
                            <Label x:Name="DirectionLabel" FontSize="13"
                                   HorizontalTextAlignment="Center" TextColor="{StaticResource Gray400}" />
                            <Label x:Name="PositionLabel" FontSize="13"
                                   HorizontalTextAlignment="Center" TextColor="{StaticResource Gray400}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </swipeCardView:SwipeCardView.ItemTemplate>
        </swipeCardView:SwipeCardView>

        <!-- Top item badge -->
        <Border Grid.Row="1" StrokeShape="RoundRectangle 10" Stroke="Transparent"
                BackgroundColor="#F0EBFF" Padding="12,6" HorizontalOptions="Center">
            <HorizontalStackLayout Spacing="4">
                <Label Text="TopItem:" FontSize="12" TextColor="{StaticResource Gray400}" VerticalOptions="Center" />
                <Label Text="{Binding TopItem}" FontSize="12" FontAttributes="Bold"
                       TextColor="{StaticResource Primary}" VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Border>

        <!-- Controls panel -->
        <ScrollView Grid.Row="2">
            <VerticalStackLayout Spacing="10">
                <!-- Dragging directions -->
                <Border StrokeShape="RoundRectangle 12" Stroke="{StaticResource Gray100}"
                        BackgroundColor="Transparent" Padding="12,8">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Dragging Directions" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource Gray500}" />
                        <FlexLayout JustifyContent="SpaceBetween">
                            <HorizontalStackLayout Spacing="2">
                                <Switch IsToggled="{Binding IsDraggingRightSupported}" />
                                <Label Text="R" VerticalOptions="Center" FontSize="12" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="2">
                                <Switch IsToggled="{Binding IsDraggingLeftSupported}" />
                                <Label Text="L" VerticalOptions="Center" FontSize="12" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="2">
                                <Switch IsToggled="{Binding IsDraggingUpSupported}" />
                                <Label Text="U" VerticalOptions="Center" FontSize="12" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="2">
                                <Switch IsToggled="{Binding IsDraggingDownSupported}" />
                                <Label Text="D" VerticalOptions="Center" FontSize="12" />
                            </HorizontalStackLayout>
                        </FlexLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Swipe directions -->
                <Border StrokeShape="RoundRectangle 12" Stroke="{StaticResource Gray100}"
                        BackgroundColor="Transparent" Padding="12,8">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Swipe Directions" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource Gray500}" />
                        <FlexLayout JustifyContent="SpaceBetween">
                            <HorizontalStackLayout Spacing="2">
                                <Switch IsToggled="{Binding IsSwipeRightSupported}" />
                                <Label Text="R" VerticalOptions="Center" FontSize="12" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="2">
                                <Switch IsToggled="{Binding IsSwipeLeftSupported}" />
                                <Label Text="L" VerticalOptions="Center" FontSize="12" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="2">
                                <Switch IsToggled="{Binding IsSwipeUpSupported}" />
                                <Label Text="U" VerticalOptions="Center" FontSize="12" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="2">
                                <Switch IsToggled="{Binding IsSwipeDownSupported}" />
                                <Label Text="D" VerticalOptions="Center" FontSize="12" />
                            </HorizontalStackLayout>
                        </FlexLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Numeric settings -->
                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                    <VerticalStackLayout>
                        <Label Text="Threshold" FontSize="10" TextColor="{StaticResource Gray400}" />
                        <Entry Text="{Binding Threshold}" Keyboard="Numeric" FontSize="14" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1">
                        <Label Text="Anim (ms)" FontSize="10" TextColor="{StaticResource Gray400}" />
                        <Entry Text="{Binding AnimationLength}" Keyboard="Numeric" FontSize="14" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="2">
                        <Label Text="Scale" FontSize="10" TextColor="{StaticResource Gray400}" />
                        <Entry Text="{Binding BackCardScale}" Keyboard="Numeric" FontSize="14" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="3" VerticalOptions="Center">
                        <HorizontalStackLayout Spacing="4">
                            <Label Text="Loop" FontSize="12" VerticalOptions="Center" TextColor="{StaticResource Gray400}" />
                            <Switch IsToggled="{Binding IsLoopCards}" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Grid>

                <!-- Rotation slider -->
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                    <Label Text="Rotation" VerticalOptions="Center" FontSize="12" TextColor="{StaticResource Gray400}" />
                    <Slider Grid.Column="1" Minimum="0" Maximum="360" Value="{Binding CardRotation}" />
                    <Label Grid.Column="2" Text="{Binding CardRotation, StringFormat='{0:F0}°'}"
                           VerticalOptions="Center" FontSize="12" FontAttributes="Bold"
                           TextColor="{StaticResource Primary}" WidthRequest="36" />
                </Grid>

                <!-- Stack settings -->
                <Border StrokeShape="RoundRectangle 12" Stroke="{StaticResource Gray100}"
                        BackgroundColor="Transparent" Padding="12,8">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Stack Effect" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource Gray500}" />
                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                            <VerticalStackLayout>
                                <Label Text="Depth" FontSize="10" TextColor="{StaticResource Gray400}" />
                                <Entry Text="{Binding StackDepth}" Keyboard="Numeric" FontSize="14" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="Offset" FontSize="10" TextColor="{StaticResource Gray400}" />
                                <Entry Text="{Binding StackOffset}" Keyboard="Numeric" FontSize="14" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2">
                                <Label Text="Scale Step" FontSize="10" TextColor="{StaticResource Gray400}" />
                                <Entry Text="{Binding StackScaleStep}" Keyboard="Numeric" FontSize="14" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="3" VerticalOptions="End">
                                <Label Text="Direction" FontSize="10" TextColor="{StaticResource Gray400}" />
                                <HorizontalStackLayout Spacing="4">
                                    <Label Text="↓" FontSize="14" TextColor="{StaticResource Gray400}" />
                                    <Switch IsToggled="{Binding IsStackDirectionTop}" />
                                    <Label Text="↑" FontSize="14" TextColor="{StaticResource Gray400}" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Grid>
                        <VerticalStackLayout>
                            <Label Text="Card Color (hex, e.g. #5A7050)" FontSize="10" TextColor="{StaticResource Gray400}" />
                            <Entry Text="{Binding StackCardColorText}" Placeholder="#RRGGBB" FontSize="14" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Action buttons -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Text="Clear" Command="{Binding ClearItemsCommand}"
                            BackgroundColor="#FFE8E5" TextColor="#E53935" FontSize="13" />
                    <Button Grid.Column="1" Text="Add 5" Command="{Binding AddItemsCommand}" FontSize="13" />
                </Grid>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>